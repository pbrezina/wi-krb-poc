#!/usr/bin/env bash

echo "SSS_BOT_ORIGINAL_USER=$SSS_BOT_ORIGINAL_USER"
echo "SSS_BOT_ORIGINAL_SHELL=$SSS_BOT_ORIGINAL_SHELL"
echo "SSS_BOT_REQUEST_ID=$SSS_BOT_REQUEST_ID"
echo "SSS_BOT_AGENT=$SSS_BOT_AGENT"
echo "SSS_BOT_MODEL=$SSS_BOT_MODEL"
echo "SSS_BOT_TOOL=$SSS_BOT_TOOL"

logger --journald <<EOF
MESSAGE=Bot action [$SSS_BOT_TOOL:$SSS_BOT_REQUEST_ID]: $SSS_BOT_ORIGINAL_SHELL $*
SYSLOG_IDENTIFIER=sss-confined-shell
PRIORITY=6
SSS_BOT_ORIGINAL_USER=$SSS_BOT_ORIGINAL_USER
SSS_BOT_ORIGINAL_SHELL=$SSS_BOT_ORIGINAL_SHELL
SSS_BOT_REQUEST_ID=$SSS_BOT_REQUEST_ID
SSS_BOT_AGENT=$SSS_BOT_AGENT
SSS_BOT_MODEL=$SSS_BOT_MODEL
SSS_BOT_TOOL=$SSS_BOT_TOOL
EOF

exec "$SSS_BOT_ORIGINAL_SHELL" "$@"
